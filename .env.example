# ── 必填 ──────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── 可选（不填则跳过对应功能）────────────────────────────────────────────────
# 网页搜索：https://brave.com/search/api/
BRAVE_API_KEY=

# 美联储经济数据：https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# 实时金融数据：https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=

# ── 安全 ───────────────────────────────────────────────────────────────────────
# 随机字符串，用于 JWT 签名，务必修改
JWT_SECRET=change-me-to-a-random-secret

# ── 模型参数（可保持默认）──────────────────────────────────────────────────────
MODEL_NAME=gpt-4o
MAX_TOOL_ROUNDS=5
TOOL_CALL_TIMEOUT=30
LLM_CALL_TIMEOUT=180
MAX_TOOL_OUTPUT_TO_LLM=3000
SUMMARIZE_THRESHOLD=10
